        &lt;tps:charStyleDef&gt;
            &lt;tps:name&gt;cite_bib&lt;/tps:name&gt;
            &lt;tps:basedOn&gt;*&lt;/tps:basedOn&gt;
            &lt;tps:leading&gt;0 pt&lt;/tps:leading&gt;
        &lt;/tps:charStyleDef&gt;
    &lt;/tps:definition&gt;
    &lt;tps:definition tag="charStyleDef"&gt;
        &lt;tps:charStyleDef&gt;
            &lt;tps:name&gt;cite_bibLEGEND&lt;/tps:name&gt;
            &lt;tps:basedOn&gt;*&lt;/tps:basedOn&gt;
            &lt;tps:font&gt;
                &lt;tps:name&gt;OTNEJMScalaSansLFSmallCap&lt;/tps:name&gt;
                &lt;tps:style&gt;Regular&lt;/tps:style&gt;
            &lt;/tps:font&gt;
